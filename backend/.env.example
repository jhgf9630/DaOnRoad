# ── Kakao REST API Key (주소/장소 검색용) ──────────────────────────
# 발급: developers.kakao.com → 내 앱 → REST API 키
# 필수: 제품설정 → 카카오맵 → 사용 설정 ON
KAKAO_API_KEY=your_kakao_rest_api_key_here

# ── OSRM 실제 도로 경로 (선택, 설정 시 자동 활성화) ─────────────────
# 옵션 A. 공용 무료 서버 (제한 있음, 테스트용)
# OSRM_BASE_URL=http://router.project-osrm.org
#
# 옵션 B. 로컬 Docker 서버 (권장, 제한 없음)
# 1. 한국 OSM 데이터 다운로드:
#    wget https://download.geofabrik.de/asia/south-korea-latest.osm.pbf
# 2. OSRM 전처리:
#    docker run -v $(pwd)/maps:/data osrm/osrm-backend:latest osrm-extract -p /opt/car.lua /data/south-korea-latest.osm.pbf
#    docker run -v $(pwd)/maps:/data osrm/osrm-backend:latest osrm-partition /data/south-korea-latest.osrm
#    docker run -v $(pwd)/maps:/data osrm/osrm-backend:latest osrm-customize /data/south-korea-latest.osrm
# 3. 서버 실행:
#    docker run -p 5000:5000 -v $(pwd)/maps:/data osrm/osrm-backend:latest osrm-routed --algorithm mld /data/south-korea-latest.osrm
# OSRM_BASE_URL=http://localhost:5000
