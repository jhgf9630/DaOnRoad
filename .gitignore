# ════════════════════════════════════════════════════════
# DaOnRoad .gitignore
# ════════════════════════════════════════════════════════

# ── API 키 / 환경설정 (절대 커밋 금지) ──────────────────
backend/.env
.env
.env.local
.env.production

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg
pip-log.txt

# 가상환경 (Docker로 대체됨, 로컬에 있어도 커밋 불필요)
backend/venv/
venv/
.venv/
env/

# ── 캐시 (자동 생성, 커밋 불필요) ───────────────────────
backend/cache/

# ── Node.js / Electron ───────────────────────────────────
frontend/node_modules/
npm-debug.log*
yarn-error.log*

# ── 패키징 결과물 ────────────────────────────────────────
dist/
frontend/dist/
*.exe
*.dmg
*.AppImage
*.deb
*.rpm

# ── OSRM 지도 데이터 (수 GB, Git에 올리면 안 됨) ─────────
osrm-data/
*.osm.pbf
*.osrm
*.osrm.cells
*.osrm.cnbg
*.osrm.cnbg_to_ebg
*.osrm.dbg
*.osrm.ebg
*.osrm.ebg_nodes
*.osrm.edges
*.osrm.enw
*.osrm.fileIndex
*.osrm.geometry
*.osrm.icd
*.osrm.maneuver_overrides
*.osrm.mldgr
*.osrm.names
*.osrm.nbg_nodes
*.osrm.partition
*.osrm.properties
*.osrm.ramIndex
*.osrm.restrictions
*.osrm.timestamp
*.osrm.tld
*.osrm.tls
*.osrm.turn_duration_penalties
*.osrm.turn_penalties_index
*.osrm.turn_weight_penalties
*.osrm.cell_metrics

# ── Excel 파일 (업로드/결과 파일) ───────────────────────
*.xlsx
*.xls

# ── OS 파일 ──────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── IDE ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~

# ── 로그 ─────────────────────────────────────────────────
*.log
logs/

# ── Docker 관련 ──────────────────────────────────────────
.docker/
